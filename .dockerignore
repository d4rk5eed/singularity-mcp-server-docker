# ── Контроль версий ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── AI-контекст (правила, спеки, Memento) ────────────────────────────────────
.ai/
.rules

# ── Оригинальный дистрибутив (не нужен — копируем из локальной ФС напрямую) ──
*.mcpb

# ── Документация ──────────────────────────────────────────────────────────────
README.md
*.md

# ── Тесты ─────────────────────────────────────────────────────────────────────
__tests__/
mcp_test.py

# ── Docker-файлы оркестрации (не нужны внутри образа) ────────────────────────
docker-compose.yml
.dockerignore

# ── Среда разработки ──────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── node_modules — НЕ копируем из локальной ФС.
# Dockerfile выполняет npm install --omit=dev внутри образа.
# package.json и package-lock.json намеренно НЕ исключены — они нужны для сборки.
node_modules/

# ── Source maps (не нужны в продакшене) ──────────────────────────────────────
*.map

# ── Логи и временные файлы ───────────────────────────────────────────────────
*.log
npm-debug.log*
.npm/
